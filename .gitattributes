# 기본: 텍스트 파일은 자동 감지
* text=auto

# 항상 LF로 유지 (Linux 서버, GitHub Actions 환경 기준)
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.html text eol=lf

# 바이너리 파일 — 변환 안 함
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
